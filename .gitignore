# ─── Laravel Core ────────────────────────────────────────────
/vendor
/node_modules
/public/hot
/public/build
/public/storage
/storage/*.key
/storage/pail

# ─── Environment & Secrets ───────────────────────────────────
.env
.env.*
!.env.example
/auth.json

# ─── IDE & Editor ────────────────────────────────────────────
/.idea
/.vscode
/.nova
/.zed
/.cursor/
/.codex
.phpactor.json
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php

# ─── Testing & Cache ─────────────────────────────────────────
/.phpunit.cache
.phpunit.result.cache
/coverage
*.cache

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS Files ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Homestead & Vagrant ─────────────────────────────────────
Homestead.json
Homestead.yaml
.vagrant/

# ─── Backup & Temporary ──────────────────────────────────────
*.backup
*.bak
*.swp
*.swo
*~
.tmp

# ─── Database ────────────────────────────────────────────────
*.sqlite
*.sqlite-journal
/database/*.sqlite
/database/*.sqlite-journal

# ─── Sensitive Data ──────────────────────────────────────────
/storage/app/private/*
!/storage/app/private/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/logs/*
!/storage/logs/.gitkeep

# ─── Project Specific ────────────────────────────────────────
PROJECT_MEMORY.md
UPDATE_LOG.md

# ─── Keep Important Files ────────────────────────────────────
# Documentation should be committed
# !/docs

# Keep .gitkeep files
!.gitkeep
!.gitignore

