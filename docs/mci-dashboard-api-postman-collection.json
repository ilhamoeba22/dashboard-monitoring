    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "POST Clear Cache",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/{{api_version}}/dashboard/clear-cache",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "dashboard", "clear-cache"]
            }
          },
          "response": []
