          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{api_version}}/dashboard/chart/saving",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "dashboard", "chart", "saving"]
            }
          },
          "response": []
