        {
          "name": "GET Saving Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{api_version}}/dashboard/metrics/saving",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "dashboard", "metrics", "saving"]
            }
          },
          "response": []
        },
        {
          "name": "GET Deposito Metrics",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/{{api_version}}/dashboard/metrics/deposito",
              "host": ["{{base_url}}"],
              "path": ["{{api_version}}", "dashboard", "metrics", "deposito"]
            }
          },
          "response": []
