                    "version": "v1"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/dashboard/metrics/saving": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get Saving Metrics",
        "description": "Retrieve saving/key metrics (Saldo, NOA, AO)",
        "operationId": "getSavingMetrics",
        "responses": {
          "200": {
            "description": "Successfully retrieved saving metrics",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "total_saldo": 250000000000,
                    "saldo_formatted": "Rp 250.000.000.000",
                    "total_noa": 5000,
                    "total_ao": 75,
                    "growth": {
                      "value": "8,50%",
                      "class": "text-success",
                      "raw": 8.5
                    },
                    "noa_growth": {
                      "value": "5,20%",
                      "class": "text-success",
                      "raw": 5.2
                    },
                    "ao_growth": {
                      "value": "1,50%",
                      "class": "text-success",
                      "raw": 1.5
                    }
                  },
                  "meta": {
                    "generated_at": "2026-04-24T10:30:00+07:00",
                    "cache_ttl": 60,
                    "version": "v1"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/v1/dashboard/metrics/deposito": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Get Deposito Metrics",
        "description": "Retrieve deposito key metrics (Saldo, BAGHAS, NOA, AO)",
        "operationId": "getDepositoMetrics",
        "responses": {
          "200": {
            "description": "Successfully retrieved deposito metrics",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "total_saldo": 180000000000,
                    "saldo_formatted": "Rp 180.000.000.000",
                    "total_baghas": 18500000000,
                    "baghas_formatted": "Rp 18.500.000.000",
                    "total_noa": 800,
                    "total_ao": 45,
